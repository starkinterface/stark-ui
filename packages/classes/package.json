{
  "name": "@stark-ui/classes",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/starkinterface/stark-ui",
    "directory": "packages/classes"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      }
    },
    "./components": {
      "import": {
        "types": "./src/components/index.ts",
        "default": "./src/components/index.ts"
      }
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc"
  },
  "dependencies": {
    "tailwind-variants": "catalog:"
  },
  "devDependencies": {
    "@stark-ui/tsconfig": "workspace:*",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  }
}
