{
  "name": "@stark-ui/theme-stark",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/starkinterface/stark-ui",
    "directory": "packages/theme-stark"
  },
  "style": "./src/index.css",
  "files": [
    "src",
    "!src/entrypoint.css"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./src/index.css",
  "exports": {
    ".": {
      "style": "./src/index.css",
      "default": "./src/index.css"
    },
    "./schemes/*": {
      "style": "./src/base/schemes/*.css",
      "default": "./src/base/schemes/*.css"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@stark-ui/tsconfig": "workspace:*"
  },
  "peerDependencies": {
    "tailwindcss": "catalog:"
  }
}
